{
  "name": "kami-prompter",
  "publisher": "KamiDev",
  "displayName": "Kami Prompter",
  "description": "Asistente de ingeniería de prompts de alta calidad dentro de VSCode.",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KamiDeveloper/kami-prompter.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kamiPrompter.open",
        "title": "Kami Prompter: Open"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run build",
    "watch": "node esbuild.config.js --watch",
    "build": "node esbuild.config.js",
    "package": "node esbuild.config.js --production",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@preact/signals-core": "^1.14.0"
  }
}
